{
    "name": "hadi2230/aala-niroo-ams",
    "description": "Aala Niroo Asset Management System - Professional Version",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "dompdf/dompdf": "^3.1",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.4",
        "phpmailer/phpmailer": "^6.8",
        "firebase/php-jwt": "^6.8",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/var-dumper": "^6.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Controllers\\": "app/Controllers/",
            "App\\Models\\": "app/Models/",
            "App\\Services\\": "app/Services/",
            "App\\Middleware\\": "app/Middleware/",
            "App\\Helpers\\": "app/Helpers/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"copy('.env.example', '.env');\"",
            "php -r \"if (!file_exists('logs')) mkdir('logs', 0755, true);\"",
            "php -r \"if (!file_exists('uploads')) mkdir('uploads', 0755, true);\""
        ]
    },
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true
}
